# Supabase Auth only (mobile uses this for sign-in/sign-up and session)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API base URL (all table access goes through the server, not direct Supabase)
# e.g. http://localhost:5000 for local server, or your deployed server URL
EXPO_PUBLIC_API_URL=http://localhost:5000
